{
  "name": "@kotoba-lang/svgraph",
  "version": "0.1.52",
  "description": "Browser-only SVGraph editor and SVG to PresentationML/PPTX converter.",
  "keywords": [
    "svg",
    "svgraph",
    "presentationml",
    "pptx",
    "web"
  ],
  "private": false,
  "type": "module",
  "main": "./docs/app.js",
  "types": "./docs/app.d.ts",
  "exports": {
    ".": {
      "types": "./docs/app.d.ts",
      "default": "./docs/app.js"
    },
    "./web/app.ts": "./web/app.ts"
  },
  "bin": {
    "svgraph-browser": "bin/svgraph.cljs",
    "svgraph": "bin/svgraph.cljs"
  },
  "homepage": "https://kotoba-lang.github.io/svgraph/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kotoba-lang/svgraph.git"
  },
  "bugs": {
    "url": "https://github.com/kotoba-lang/svgraph/issues"
  },
  "license": "MIT",
  "files": [
    "bin",
    "docs",
    "examples/alpha.dml",
    "examples/color.dml",
    "examples/color-invalid-modifier.dml",
    "examples/connector-style-ref.dml",
    "examples/fill-effects.dml",
    "examples/freeform-closed-duplicate.dml",
    "examples/freeform.dml",
    "examples/group.dml",
    "examples/line-arrow.dml",
    "examples/line-flip-bool.dml",
    "examples/line-invalid-dash.dml",
    "examples/line-style.dml",
    "examples/picture.dml",
    "examples/picture-invalid-alpha.dml",
    "examples/picture-invalid-src-rect.dml",
    "examples/preset.dml",
    "examples/sample.svg",
    "examples/style-ref.dml",
    "examples/svgraph.svg",
    "examples/table-border-effects.dml",
    "examples/table-fill-effects.dml",
    "examples/table-rich.dml",
    "examples/table-merge-bool.dml",
    "examples/table-scaled.dml",
    "examples/table-scaled-insets.dml",
    "examples/text-caps.dml",
    "examples/text-baseline-threshold.dml",
    "examples/text-bullets.dml",
    "examples/text-defaults.dml",
    "examples/text-layout.dml",
    "examples/text-invalid-numeric.dml",
    "examples/text-invalid-level.dml",
    "examples/text-shape-paint.dml",
    "examples/text-style.dml",
    "web",
    "README.md",
    "LICENSE",
    "MIGRATION.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build:web": "tsc -p tsconfig.web.json",
    "check:web": "tsc -p tsconfig.web.json --noEmit",
    "test:maturity": "nbb tests/maturity_test.cljs",
    "check:package": "nbb --classpath tests tests/package_api_smoke.cljs && nbb --classpath tests tests/package_svg_smoke.cljs && nbb --classpath tests tests/package_text_smoke.cljs && nbb --classpath tests tests/package_table_smoke.cljs"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "nbb": "^1.5.211"
  }
}
